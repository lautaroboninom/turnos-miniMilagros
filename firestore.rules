rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: services
    // Document ID: string (e.g. valid random ID or name-based)
    // Fields:
    //   - name: string (required) - Name of service
    //   - durationMinutes: number (required) - Service duration in minutes
    //   - price: number (required) - Price in ARS
    //   - isActive: bool (required) - Whether the service is currently offered
    //   - createdAt: timestamp (required)
    //   - employeeId: string (optional) - Assigned employee ID
    //   - employeeName: string (optional) - Assigned employee name snapshot
    //   - imageUrl: string (optional) - Public image URL
    //   - imageSourceType: string (optional) ['url', 'upload']
    //   - imageStoragePath: string (optional) - Firebase Storage path
    //   - imageUpdatedAt: string (optional)
    //
    // Collection: appointments
    // Document ID: string
    // Fields:
    //   - serviceId: string (required)
    //   - serviceName: string (required)
    //   - durationMinutes: number (required)
    //   - price: number (required)
    //   - date: string (required) YYYY-MM-DD
    //   - startTime: string (required) HH:mm
    //   - endTime: string (required) HH:mm
    //   - clientFirstName: string (required)
    //   - clientLastName: string (required)
    //   - status: string (required) ['pending', 'confirmed', 'cancelled']
    //   - depositAmount: number (required)
    //   - createdAt: timestamp (required)
    //   - employeeId: string (optional) - Assigned employee ID
    //   - employeeName: string (optional) - Assigned employee name snapshot
    //
    // Collection: employees
    // Document ID: string
    // Fields:
    //   - name: string (required)
    //   - createdAt: string (required)
    //   - updatedAt: string (required)
    //
    // Collection: settings
    // Document ID: 'global'
    // Fields:
    //   - depositAmount: number (required)
    //   - galleryImages: list (required) [{src, alt}]
    //   - shareSlotTimes: list (optional) ['08:00', '10:00', ...]
    //   - updatedAt: string (required)
    // ===============================================================
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Only the designated admin emails can access the backoffice.
    function isAdmin() {
      return isAuthenticated()
        && request.auth.token.email_verified == true
        && (
          request.auth.token.email == 'milagrosisas34@gmail.com'
          || request.auth.token.email == 'lautaroboninom@gmail.com'
        );
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidService(data) {
      return hasOnlyAllowedFields(['name', 'durationMinutes', 'price', 'isActive', 'createdAt', 'employeeId', 'employeeName', 'imageUrl', 'imageSourceType', 'imageStoragePath', 'imageUpdatedAt']) &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
        data.durationMinutes is number && data.durationMinutes > 0 &&
        data.price is number && data.price >= 0 &&
        data.isActive is bool &&
        (!data.keys().hasAny(['employeeId']) || (data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() <= 120)) &&
        (!data.keys().hasAny(['employeeName']) || (data.employeeName is string && data.employeeName.size() > 0 && data.employeeName.size() <= 80)) &&
        (!data.keys().hasAny(['imageUrl']) || (data.imageUrl is string && data.imageUrl.size() <= 2000)) &&
        (!data.keys().hasAny(['imageSourceType']) || data.imageSourceType in ['url', 'upload']) &&
        (!data.keys().hasAny(['imageStoragePath']) || (data.imageStoragePath is string && data.imageStoragePath.size() <= 300)) &&
        (!data.keys().hasAny(['imageUpdatedAt']) || data.imageUpdatedAt is string); // createdAt might be server timestamp, usually handled natively
    }

    function isValidAppointment(data) {
      return hasOnlyAllowedFields(['serviceId', 'serviceName', 'durationMinutes', 'price', 'date', 'startTime', 'endTime', 'clientFirstName', 'clientLastName', 'status', 'depositAmount', 'createdAt', 'employeeId', 'employeeName']) &&
        data.serviceId is string && data.serviceId.size() > 0 &&
        data.serviceName is string && data.serviceName.size() > 0 && data.serviceName.size() <= 100 &&
        data.durationMinutes is number && data.durationMinutes > 0 &&
        data.price is number && data.price >= 0 &&
        data.date is string && data.date.size() == 10 &&
        data.startTime is string && data.startTime.size() == 5 &&
        data.endTime is string && data.endTime.size() == 5 &&
        data.clientFirstName is string && data.clientFirstName.size() > 0 && data.clientFirstName.size() <= 50 &&
        data.clientLastName is string && data.clientLastName.size() > 0 && data.clientLastName.size() <= 50 &&
        data.status in ['pending', 'confirmed', 'cancelled'] &&
        (!data.keys().hasAny(['employeeId']) || (data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() <= 120)) &&
        (!data.keys().hasAny(['employeeName']) || (data.employeeName is string && data.employeeName.size() > 0 && data.employeeName.size() <= 80)) &&
        data.depositAmount is number && data.depositAmount >= 0;
    }

    function isValidEmployee(data) {
      return data.keys().hasOnly(['name', 'createdAt', 'updatedAt']) &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 80 &&
        data.createdAt is string &&
        data.updatedAt is string;
    }

    function isValidSettings(data) {
      return data.keys().hasOnly(['depositAmount', 'galleryImages', 'shareSlotTimes', 'updatedAt']) &&
        data.depositAmount is number && data.depositAmount >= 0 &&
        data.updatedAt is string &&
        data.galleryImages is list &&
        data.galleryImages.size() > 0 &&
        data.galleryImages.size() <= 20 &&
        (!data.keys().hasAny(['shareSlotTimes']) || (
          data.shareSlotTimes is list &&
          data.shareSlotTimes.size() > 0 &&
          data.shareSlotTimes.size() <= 8
        ));
    }
    
    // ===============================================================
    // Rules
    // ===============================================================
    match /services/{serviceId} {
      // Anyone can see active services
      // Using simple read as public allows listing for the booking page
      allow read: if true; 
      allow create: if isAdmin() && isValidService(request.resource.data);
      allow update: if isAdmin() && isValidService(request.resource.data);
      allow delete: if isAdmin();
    }
    
    match /appointments/{appointmentId} {
      // Public can read to check availability (need to query by date/time)
      // Public can only create appointments.
      allow read: if true;
      // Allow unauthenticated creation so users don't have to log in to book
      allow create: if isValidAppointment(request.resource.data) && request.resource.data.status == 'pending';
      // Admin can update/cancel/view all appointments
      allow update: if isAdmin() && isValidAppointment(request.resource.data);
      allow delete: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidEmployee(request.resource.data);
      allow update: if isAdmin() && isValidEmployee(request.resource.data);
      allow delete: if isAdmin() && employeeId != "milagros";
    }
    
    match /settings/{docId} {
      // Public can read settings (e.g. to know deposit amount)
      allow read: if docId == 'global';
      allow write: if isAdmin() && docId == 'global' && isValidSettings(request.resource.data);
    }
  }
}
